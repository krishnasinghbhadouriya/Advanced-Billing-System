@model List<Billing_System.Models.Product>

<h2>Product List</h2>

<a href="/Billing/AddProduct">Add Product</a>
<a href="/Billing/Bill">Generate Bill</a>

<table border="1" cellpadding="10">
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Price</th>
        <th>Qty</th>
        <th>Total</th>
        <th>Action</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>
            <td>@item.Price</td>
            <td>@item.Quantity</td>
            <td>@(item.Price * item.Quantity)</td>
            <td>
                <a href="/Billing/Delete/@item.Id">Delete</a>
            </td>
        </tr>
    }
</table>
